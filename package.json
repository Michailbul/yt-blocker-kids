{
  "name": "yt-kids-guard",
  "version": "1.0.0",
  "private": true,
  "description": "Parental control Chrome extension for YouTube",
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../yt-kids-guard.zip ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.17.0"
  }
}
